{
    "compilerOptions": {
        "typeRoots": [
            "./node_modules/@types",
            "src/helper/types"
        ],
        "experimentalDecorators": true,
        "target": "ESNext",
        "module": "CommonJS",
        "moduleResolution": "node",
        "sourceMap": true,
        "outDir": "../tests-out",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
    },
    "include": [
        "**/*.ts",
        "playwright.config.ts",
        "src/support/world.ts",
        "**/webui/pages/**/*.ts",
        "src/**/**/**/*.ts"
    ],
    "exclude": ["node_modules", "dist", "reports"]
}